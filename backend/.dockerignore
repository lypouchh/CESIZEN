# Fichiers d'environnement et secrets
.env
.env.*
!.env.example

# Métadonnées Git, IDE et OS
.git
.gitignore
.idea
.vscode
.DS_Store

# Dépendances gérées à l'intérieur du container
/vendor
/node_modules

# Fichiers de cache et de logs de Laravel (générés à l'exécution)
/storage/logs
/storage/framework/cache/data
/storage/framework/sessions
/storage/framework/views

# Répertoire de tests non nécessaire en production
/tests