# Environnement PROD (branche main) — cesizen-prod
# Copier ce fichier en `.env.prod` (non versionné, voir .gitignore) et renseigner de vraies valeurs
# avant le premier déploiement. En CD, ce fichier est régénéré depuis les secrets GitHub de
# l'environnement "prod" (voir README > Secrets requis).
#
# Chargement: docker compose --env-file .env.prod -f docker-compose.prod.yml -f docker-compose.bluegreen.yml -p cesizen-prod up -d

COMPOSE_PROJECT_NAME=cesizen-prod
IMAGE_TAG=latest

# Ports hôte (doivent rester uniques par environnement)
DB_PORT=3308
NGINX_PORT=8002
FRONTEND_PORT=5175

# Base de données
DB_DATABASE=cesizen
DB_USERNAME=cesizen_user
DB_PASSWORD=CHANGEME
DB_ROOT_PASSWORD=CHANGEME

# JWT (secret dédié à cet environnement, jamais partagé, min 32 caractères)
JWT_SECRET=CHANGEME_min_32_characters_long
JWT_TTL=15
JWT_REFRESH_TOKEN_TTL=10080

# Application
APP_URL=https://CHANGEME
CORS_ALLOWED_ORIGINS=https://CHANGEME
VITE_API_BASE_URL=http://localhost:8002
